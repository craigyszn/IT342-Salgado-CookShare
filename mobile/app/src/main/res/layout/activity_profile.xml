<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F3F4F6">

    <!-- Navbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#FFFFFF"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <FrameLayout
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_logo_rounded">
            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_chef_hat"
                app:tint="#FFFFFF"/>
        </FrameLayout>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="My Profile"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="#111827"/>

        <Button
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="← Back"
            android:textSize="13sp"
            android:background="@drawable/bg_chip_inactive"
            android:textColor="#374151"
            style="@android:style/Widget.Button"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Avatar + Stats Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_stat_card"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="14dp">

                <!-- Avatar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <FrameLayout
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:background="@drawable/bg_logo_circle">
                        <ImageView
                            android:id="@+id/ivAvatar"
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:scaleType="centerCrop"
                            android:visibility="gone"/>
                        <TextView
                            android:id="@+id/tvAvatarInitials"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="U"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"/>
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="14dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvFirstName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="First Name"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#111827"/>

                        <TextView
                            android:id="@+id/tvLastName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Last Name"
                            android:textSize="15sp"
                            android:textColor="#374151"/>

                        <TextView
                            android:id="@+id/tvEmail"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="email@example.com"
                            android:textSize="13sp"
                            android:textColor="#6B7280"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Stats Row -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Account Stats"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#111827"
                    android:layout_marginBottom="10dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center_horizontal">
                        <TextView
                            android:id="@+id/tvRecipesShared"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="#F97316"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Recipes"
                            android:textSize="11sp"
                            android:textColor="#6B7280"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center_horizontal">
                        <TextView
                            android:id="@+id/tvFavorites"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="#3B82F6"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Favorites"
                            android:textSize="11sp"
                            android:textColor="#6B7280"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center_horizontal">
                        <TextView
                            android:id="@+id/tvComments"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="#22C55E"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Comments"
                            android:textSize="11sp"
                            android:textColor="#6B7280"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Tabs -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#FFFFFF"
                android:layout_marginBottom="14dp">

                <TextView
                    android:id="@+id/tabProfile"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="Profile"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"/>

                <TextView
                    android:id="@+id/tabRecipes"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="My Recipes"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/profileContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_stat_card"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Personal Information"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#111827"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your account details from registration"
                    android:textSize="12sp"
                    android:textColor="#6B7280"
                    android:layout_marginBottom="16dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="First Name" android:textSize="12sp" android:textStyle="bold"
                    android:textColor="#F97316" android:layout_marginBottom="4dp"/>
                <TextView android:id="@+id/tvProfileFirstName" android:layout_width="match_parent"
                    android:layout_height="44dp" android:background="@drawable/bg_input"
                    android:paddingStart="14dp" android:gravity="center_vertical"
                    android:textSize="14sp" android:textColor="#374151"
                    android:layout_marginBottom="12dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Last Name" android:textSize="12sp" android:textStyle="bold"
                    android:textColor="#F97316" android:layout_marginBottom="4dp"/>
                <TextView android:id="@+id/tvProfileLastName" android:layout_width="match_parent"
                    android:layout_height="44dp" android:background="@drawable/bg_input"
                    android:paddingStart="14dp" android:gravity="center_vertical"
                    android:textSize="14sp" android:textColor="#374151"
                    android:layout_marginBottom="12dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Email" android:textSize="12sp" android:textStyle="bold"
                    android:textColor="#F97316" android:layout_marginBottom="4dp"/>
                <TextView android:id="@+id/tvProfileEmail" android:layout_width="match_parent"
                    android:layout_height="44dp" android:background="@drawable/bg_input"
                    android:paddingStart="14dp" android:gravity="center_vertical"
                    android:textSize="14sp" android:textColor="#374151"
                    android:layout_marginBottom="12dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Member Since" android:textSize="12sp" android:textStyle="bold"
                    android:textColor="#F97316" android:layout_marginBottom="4dp"/>
                <TextView android:id="@+id/tvMemberSince" android:layout_width="match_parent"
                    android:layout_height="44dp" android:background="@drawable/bg_input"
                    android:paddingStart="14dp" android:gravity="center_vertical"
                    android:text="CookShare Member"
                    android:textSize="14sp" android:textColor="#374151"/>
            </LinearLayout>

            <!-- My Recipes Content -->
            <LinearLayout
                android:id="@+id/recipesContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Create Button -->
                <Button
                    android:id="@+id/btnCreateNew"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_button_orange"
                    android:text="+ Create New Recipe"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:stateListAnimator="@null"
                    android:layout_marginBottom="14dp"
                    style="@android:style/Widget.Button"/>

                <ProgressBar
                    android:id="@+id/progressRecipes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:visibility="gone"/>

                <TextView
                    android:id="@+id/tvRecipesEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No recipes yet. Create your first recipe!"
                    android:textSize="14sp"
                    android:textColor="#9CA3AF"
                    android:gravity="center"
                    android:padding="32dp"
                    android:visibility="gone"/>

                <LinearLayout
                    android:id="@+id/recipesContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>